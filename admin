<?php
session_start();
require_once 'koneksi.php';

// If already logged in, redirect to dashboard
if (!empty($_SESSION['user_id'])) {
    header('Location: admin-dashboard.php');
    exit;
}

$error = '';
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    // Note: real_escape_string is not needed when using prepared statements (bind_param)
    $username = isset($_POST['username']) ? trim($_POST['username']) : '';
    $password = isset($_POST['password']) ? $_POST['password'] : '';

    if ($username === '' || $password === '') {
        $error = 'Masukkan username dan password.';
    } else {
        // CHANGED: 'password_hash' changed to 'password' to match common DB naming
        $stmt = $mysqli->prepare('SELECT id, username, password FROM website WHERE username = ? LIMIT 1');
        
        if ($stmt) {
            $stmt->bind_param('s', $username);
            $stmt->execute();
            $res = $stmt->get_result();
            
            if ($row = $res->fetch_assoc()) {
                // CHANGED: Using $row['password'] here as well
                if (password_verify($password, $row['password'])) {
                    // Login success
                    $_SESSION['user_id'] = $row['id'];
                    $_SESSION['username'] = $row['username'];
                    header('Location: admin-dashboard.php');
                    exit;
                } else {
                    $error = 'Username atau password salah.';
                }
            } else {
                $error = 'Username atau password salah.';
            }
            $stmt->close();
        } else {
            // This triggers if the table 'website' or column 'password' still doesn't exist
            $error = 'Database error: ' . $mysqli->error;
        }
    }
}
?>
